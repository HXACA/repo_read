{
  "name": "@reporead/cli",
  "version": "0.1.0",
  "description": "Command-line interface for RepoRead — generate, browse, ask, and research against any git repo locally.",
  "license": "MIT",
  "homepage": "https://github.com/YOUR_ORG/repo_read#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_ORG/repo_read.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/YOUR_ORG/repo_read/issues"
  },
  "keywords": ["reporead", "cli", "wiki", "code-reading", "agent", "documentation"],
  "type": "module",
  "bin": {
    "repo-read": "./dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "build:publish": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build:publish"
  },
  "dependencies": {
    "@reporead/core": "workspace:*",
    "commander": "^13.0.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "@types/react": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
