{
  "name": "@reporead/core",
  "version": "0.1.0",
  "description": "Core runtime for RepoRead — agents, pipeline, providers, tools. See the CLI package @reporead/cli for the user-facing entry point.",
  "license": "MIT",
  "homepage": "https://github.com/YOUR_ORG/repo_read#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_ORG/repo_read.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/YOUR_ORG/repo_read/issues"
  },
  "keywords": ["reporead", "wiki", "code-reading", "agent", "documentation"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "build:publish": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build:publish && pnpm run test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@vscode/ripgrep": "^1.17.1",
    "ai": "^6.0.153",
    "glob": "^13.0.6",
    "ignore": "^7.0.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
